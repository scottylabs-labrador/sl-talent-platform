{
  "name": "sl-talent-platform",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @tartan/db db:generate",
    "db:migrate": "pnpm --filter @tartan/db db:migrate",
    "db:seed": "pnpm --filter @tartan/db db:seed",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
