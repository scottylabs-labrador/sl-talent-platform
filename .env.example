# ── Core infrastructure ─────────────────────────────────────────────
# Postgres (Railway plugin; pgvector enabled by migration 0000)
DATABASE_URL=postgresql://user:pass@host:5432/railway
# Redis (Railway plugin; BullMQ queues + voice session state)
REDIS_URL=redis://default:pass@host:6379

# ── Auth (Auth.js v5) ───────────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Google OAuth client (students use hd=andrew.cmu.edu, verified server-side)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to enable the credentials-based demo login (seeded demo
# accounts only). Leave unset in production once Google OAuth is configured.
DEV_LOGIN=true

# ── Voice pipeline ──────────────────────────────────────────────────
# Cartesia (streaming STT + Sonic TTS). Without a key the CallRoom runs
# in simulation mode (clearly labeled in the UI).
CARTESIA_API_KEY=

# ── LLM gateway ─────────────────────────────────────────────────────
# OpenRouter. Without a key, agents run in deterministic stub mode.
# Routing optimized per role (see docs/DECISIONS.md D8): latency for the
# realtime rep, frontier reasoning where the artifact is the product
# (dossiers, rankings), small models for pattern checks and digests.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_REP=google/gemini-3.5-flash
OPENROUTER_MODEL_SYNTH=anthropic/claude-opus-4.8
OPENROUTER_MODEL_RECRUITER=anthropic/claude-opus-4.8
OPENROUTER_MODEL_VERIFIER=openai/gpt-5.4-nano
OPENROUTER_MODEL_CONCIERGE=anthropic/claude-sonnet-5
OPENROUTER_MODEL_COACH=anthropic/claude-sonnet-5
OPENROUTER_MODEL_SENTINEL=google/gemini-3.1-flash-lite
# Embeddings are called directly (not via OpenRouter)
EMBEDDINGS_API_KEY=

# ── Audio storage (S3) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=tartan-talent-audio
S3_REGION=us-east-1

# ── URLs ────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
WS_URL=ws://localhost:8787
